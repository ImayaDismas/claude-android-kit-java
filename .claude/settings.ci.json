{
  "permissions": {
    "allow": [
      "Bash(./gradlew test)",
      "Bash(./gradlew lint)",
      "Bash(./gradlew check)",
      "Bash(git diff:*)"
    ],
    "deny": [
      "Read(**/*.jks)",
      "Read(**/*.keystore)",
      "Read(**/keystore.properties)",
      "Read(**/local.properties)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/google-services.json)",
      "Read(**/firebase*.json)",
      "Read(**/secrets.properties)",
      "Read(**/secret.properties)",
      "Read(**/apikeys.properties)",
      "Read(**/api.properties)",
      "Read(**/gradle.properties)",

      "Read(**/*.db)",
      "Read(**/*.sqlite)",
      "Read(**/*.sqlite3)",
      "Read(**/*.realm)",
      "Read(**/databases/**)",

      "Read(**/shared_prefs/**)",
      "Read(**/*.preferences_pb)",

      "Read(**/crypto/**)",
      "Read(**/*cipher*)",
      "Read(**/*sqlcipher*)",

      "Read(**/biometric/**)",
      "Read(**/fingerprint/**)",
      "Read(**/face/**)",

      "Read(**/build/**)",
      "Read(**/.gradle/**)",
      "Read(**/captures/**)",
      "Read(**/outputs/**)",
      "Read(**/*.apk)",
      "Read(**/*.aab)",

      "Read(**/*.log)",
      "Read(**/logs/**)",
      "Read(**/crash/**)",
      "Read(**/tombstones/**)",

      "Read(.git/config)",
      "Edit(.git/**)",
      "Edit(.github/workflows/**)",
      "Edit(.gitlab-ci.yml)",
      "Edit(Jenkinsfile)",

      "Edit(**/signing/**)",
      "Read(**/certs/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",

      "Edit(android/guidelines/architecture_standard.md)",
      "Edit(CLAUDE.md)",

      "Edit(**/migration/**)",
      "Edit(**/migrations/**)",

      "Edit(**/*.pro)",
      "Edit(**/proguard-rules*)",
      "Edit(**/consumer-rules*)",

      "Edit(**/AndroidManifest.xml)",
      "Edit(**/build.gradle)",
      "Edit(**/build.gradle.kts)",

      "Edit(**/di/module/NetworkModule*)",
      "Edit(**/di/module/DatabaseModule*)",

      "Bash(rm -rf *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git push --force*)",
      "Bash(./gradlew publish*)",
      "Bash(./gradlew upload*)",
      "Bash(./gradlew assembleRelease*)",
      "Bash(./gradlew bundleRelease*)"
    ]
  },

  "autoApply": false,
  "confirmBeforeEdit": false,

  "contextFiles": [
    "CLAUDE.md",
    
    "android/guidelines/architecture_standard.md",
    "android/testing/testing_guidelines.md",
    "android/security/security_guidelines.md",

    "workflows/ci.md"
  ]
}
